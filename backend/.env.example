# ====== FurniX Backend Environment Variables ======
# Copy this file to .env and fill in your real values.

# --- Server ---
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (add your deployed frontend URL here)
CORS_ORIGIN=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5500

# --- SEO / Public URL ---
# Set this to your public canonical URL in production (used in sitemap.xml, canonical tags, Open Graph).
# Leave unset in dev — the server auto-detects from the Host header.
# SITE_URL=https://www.furnix.store

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=furnix_db

# --- Business / Tax ---
GST_RATE=0.18
SHIPPING_FEE=499
FREE_SHIPPING_THRESHOLD=25000

# --- Store info (used in receipts) ---
STORE_NAME=FurniX
STORE_EMAIL=contact@furnix.store
STORE_PHONE=+91-9000000000
# Optional: printed on the PDF invoice
STORE_GSTIN=
STORE_ADDRESS=

# --- Email (Gmail SMTP) ---
# To use Gmail:
#   1. Enable 2-Step Verification on your Google account.
#   2. Create an App Password:  https://myaccount.google.com/apppasswords
#   3. Paste the 16-character app password (no spaces) into MAIL_PASS.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your.gmail.address@gmail.com
MAIL_PASS=your_16_char_app_password
# "From" header on outgoing emails. Defaults to MAIL_USER if blank.
MAIL_FROM=
# Admin mailbox that receives every new order. Defaults to MAIL_USER if blank.
ADMIN_EMAIL=

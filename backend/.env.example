# ====== Vesta Backend Environment Variables ======
# Copy this file to .env and fill in your real values.

# --- Server ---
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (add your deployed frontend URL here)
CORS_ORIGIN=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5500

# --- SEO / Public URL ---
# Set this to your public canonical URL in production (used in sitemap.xml, canonical tags, Open Graph).
# Leave unset in dev — the server auto-detects from the Host header.
# SITE_URL=https://www.vesta.store

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=vesta_db

# --- Business / Tax ---
GST_RATE=0.18
SHIPPING_FEE=499
FREE_SHIPPING_THRESHOLD=25000

# --- Store info (used in receipts) ---
STORE_NAME=Vesta
STORE_EMAIL=contactVesta@gmail.com
STORE_PHONE=+91-7583777875
# Optional: printed on the PDF invoice
STORE_GSTIN=
STORE_ADDRESS=Puja Furniture & Hardware, Subhash Chowk, Mirana Road, Bayana, Bharatpur, Rajasthan

# --- Email (Gmail SMTP) ---
# To use Gmail:
#   1. Enable 2-Step Verification on your Google account.
#   2. Create an App Password:  https://myaccount.google.com/apppasswords
#   3. Paste the 16-character app password (no spaces) into MAIL_PASS.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your.gmail.address@gmail.com
MAIL_PASS=your_16_char_app_password
# "From" header on outgoing emails. Defaults to MAIL_USER if blank.
MAIL_FROM=
# Admin mailbox that receives every new order. Defaults to MAIL_USER if blank.
ADMIN_EMAIL=

# --- Authentication (Google Sign-In) ---
# Customers and the admin sign in with their Google account.
# Setup (one-time, ~10 minutes) — see GOOGLE_OAUTH_SETUP.md for screenshots.
#   1. Open  https://console.cloud.google.com/apis/credentials
#   2. OAuth consent screen  -> External, Testing mode is fine for local dev.
#   3. Credentials -> Create credentials -> OAuth client ID -> Web application.
#        Authorized JavaScript origins:  http://localhost:5000
#        Authorized redirect URIs:       http://localhost:5000
#   4. Paste the Client ID below. The client secret is NOT needed.
# If left blank, customers cannot sign in and the admin dashboard stays locked.
GOOGLE_CLIENT_ID=

# Secret used to sign the session cookie (any long random string).
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotate to invalidate every existing login at once.
SESSION_SECRET=

# --- Admin ---
# Comma-separated list of Gmail addresses allowed to open /admin.html.
# Each email MUST contain the substring "admin" (e.g. vesta.admin@gmail.com).
# Any Google account not on this list signs in as a regular customer.
ADMIN_EMAILS=

# --- Smart Chatbot (Groq + local embeddings RAG) ---
# Free Groq API key: https://console.groq.com/keys
# Leave blank to disable the chatbot (widget stays hidden on the site).
GROQ_API_KEY=
# Override the default chat model if you want a faster / cheaper option.
# Good choices: llama-3.3-70b-versatile, llama-3.1-8b-instant, meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL=llama-3.3-70b-versatile
# How many products the RAG retriever feeds the LLM per question.
RAG_TOP_K=6

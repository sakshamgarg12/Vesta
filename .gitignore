# ============================================================
# Vesta — root .gitignore
# ============================================================

# ---- Secrets (NEVER commit these) ----
.env
.env.local
.env.*.local
*.env
!.env.example
backend/.env
**/credentials.json
**/service-account*.json
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub

# ---- Node / npm ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ---- Logs ----
*.log
logs/

# ---- OS ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---- Editors / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ---- Build / cache ----
dist/
build/
.cache/
.tmp/
coverage/
.nyc_output/

# ---- Local DB dumps / backups ----
*.sqlite
*.sqlite3
*.db
*.sql.bak

# ---- Misc ----
*.pid
*.seed
*.pid.lock
